{
  "title": "Bosun OpenTelemetry Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": [
    "bosun",
    "opentelemetry"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Task Throughput",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(bosun_task_duration_count[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Success Rate",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "1 - (sum(rate(bosun_agent_errors_total[5m])) / clamp_min(sum(rate(bosun_task_duration_count[5m])), 1))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Average Task Duration",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum(rate(bosun_task_duration_sum[5m])) / clamp_min(sum(rate(bosun_task_duration_count[5m])),1)",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Token Usage by Model",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (bosun_model) (rate(bosun_task_tokens_total_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Cost by SDK",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (bosun_agent_sdk) (rate(bosun_task_cost_usd_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate by Type",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (bosun_error_type) (rate(bosun_agent_errors_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Interventions by Type",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "expr": "sum by (bosun_intervention_type) (rate(bosun_agent_interventions_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "traces",
      "title": "Workflow Waterfall",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "tempo",
        "uid": "${DS_TEMPO}"
      },
      "targets": [
        {
          "queryType": "traceqlSearch",
          "query": "{ resource.service.name = \"bosun\" }"
        }
      ]
    }
  ]
}