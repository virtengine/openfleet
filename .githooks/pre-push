#!/usr/bin/env bash
# Smart diff-aware pre-push hook.
#
# Strategy:
#   1. Syntax + prepublish checks (always, fast).
#   2. Collect changed files from the push range.
#   3. Only truly global files (package manifests, vitest config, test setup)
#      trigger the full suite.
#   4. For everything else, build a targeted test set from four sources:
#      a) import-graph grep (find tests that import changed modules)
#      b) module adjacency map (domain-aware cross-module coverage)
#      c) ripgrep string-match linking (catches non-import references)
#      d) directly changed test files
#   5. Deduplicate into a single vitest invocation (one startup, not three).
#   6. If targeted set exceeds 60% of all tests, run full suite instead
#      (nearly the same cost, higher confidence).
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[ -z "$ROOT" ] && exit 0
[ ! -f "$ROOT/package.json" ] && exit 0

repair_git_worktree_config() {
  [ -z "${ROOT:-}" ] && return 0
  [ ! -d "$ROOT/.git" ] && return 0
  local bare
  bare="$(git -C "$ROOT" config --bool --get core.bare 2>/dev/null || true)"
  if [ "$bare" = "true" ]; then
    echo "[hooks] repairing git config corruption: forcing core.bare=false"
    git -C "$ROOT" config --local core.bare false >/dev/null 2>&1 || true
  fi
}

trap repair_git_worktree_config EXIT

cd "$ROOT"

echo "[hooks] bosun pre-push: analyzing changed files…"

PUSH_INPUT="$(cat)"

# Always keep fast syntax validation first.
npm run syntax:check

# Validate that local imports referenced by shipped modules are in the
# package.json "files" array.  This catches the class of bug where a new
# file is imported but never added to the manifest, which causes publish
# or install failures.
node tools/prepublish-check.mjs

# Prove the packed npm artifact can still start after install. This catches
# regressions where the repo works locally but the published tarball is missing
# a runtime file required by the CLI or main package export.
npm run smoke:packed-cli

# ── Module adjacency map ────────────────────────────────────────────────────
# Maps source directory prefixes to glob patterns of tests that MUST run
# when files in that directory change, even if vitest --related doesn't
# find them via the import graph.  This captures domain-level couplings:
# e.g. workflow engine changes can break manual flows, task changes can
# break kanban views, etc.
#
# Format: "source_prefix|test_glob_1|test_glob_2|..."
# Globs are matched against tests/*.test.mjs filenames (basename only).
ADJACENCY_MAP=(
  "package.json|prepublish-check|vitest-runner|cli-*|config-validation*"
  "package-lock.json|prepublish-check|vitest-runner"
  "pnpm-lock.yaml|prepublish-check|vitest-runner"
  "yarn.lock|prepublish-check|vitest-runner"
  "npm-shrinkwrap.json|prepublish-check|vitest-runner"
  "vitest.config.mjs|vitest-runner"
  "tests/setup.mjs|vitest-runner|ui-server*|workflow-engine*|task-store*|kanban-adapter*"
  ".githooks/pre-push|prepublish-check|vitest-runner"
  "workflow/|workflow-*|workflow-task-lifecycle*|workflow-write-file-encoding*|workflow-pipeline-primitives*|workflow-research-evidence-sidecar*|manual-flows*|mcp-workflow-adapter*|bosun-native-workflow-nodes*|meeting-workflow*|run-evaluator*|state-ledger-sqlite*|webhook-gateway*|credential-store*|cron-scheduler*"
  "workflow-templates/|workflow-templates*|workflow-new-templates*|workflow-engine*|manual-flows*"
  "task/|task-*|workflow-task-lifecycle*|kanban-*|state-ledger-sqlite*|ve-orchestrator*|vk-api*|ve-kanban*"
  "kanban/|kanban-*|task-store*|task-claims*|ve-kanban*|ve-orchestrator*|vk-api*"
  "workspace/|workspace-*|shared-state*|worktree-*|worktree-recovery-regression*|sync-engine*"
  "infra/|monitor-*|heartbeat-monitor*|daemon-*|restart-*|startup-*|maintenance-*|anomaly-*|preflight*|tracing*|tui-bridge*|windows-hidden-child-processes*|weekly-agent-work-report*|workflow-task-lifecycle*|workflow-engine*"
  "agent/|agent-*|primary-agent*|fleet-*|review-agent*|analyze-agent*|autofix*|streaming-agent*|hook-library*|weekly-agent-work-report*|internal-harness*"
  "bench/|bench-swebench*|benchmark-*|task-*"
  "config/|config-*|workspace-health*|bosun-skills*|codex-config*"
  "telegram/|telegram-*|whatsapp-*|weekly-agent-work-report*"
  "voice/|voice-*|mic-*|native-call*"
  "tui/|tui-*|task-*|tui-events*|tui-bridge*|ui-server-tui-events*"
  "ui/|ui-*|tui-*|stream-timeline*|workflow-canvas-utils*|static-relative*|mui-theme*|tab-swipe*|session-theme*|session-history*|demo-*|fleet-tab*|portal-ui-smoke*"
  "site/|ui-*|stream-timeline*|static-relative*|demo-*|portal-ui-smoke*"
  "server/|ui-server*|setup-web*|bosun-mcp-server*|tunnel-*|ui-realtime*|presence*|portal-ui-smoke*|guardrails*"
  "github/|github-*|hook-profiles*"
  "git/|git-*|branch-*|diff-stats*|conflict-*"
  "shell/|*-shell*|codex-shell*|gemini-shell*|opencode-shell*|sdk-shell*|continue-detection*"
  "tools/|apply-pr-suggestions*|demo-defaults-sync*|prepublish-check*|vitest-runner*"
  "lib/|logger*|utils*|library-*|error-detector*|context-*|codebase-audit*|repo-map*|state-ledger-sqlite*"
  # Top-level runtime files that don't live in a subdirectory.
  "cli.mjs|cli-*|tui-*|smoke*"
  "bosun-tui.mjs|tui-*|cli-*"
  "utils.mjs|utils*"
  "compat.mjs|smoke*"
)

declare -A CHANGED_MAP=()
declare -A BROAD_IMPACT_MAP=()

is_zero_sha() {
  [ "$1" = "0000000000000000000000000000000000000000" ]
}

is_broad_impact_file() {
  local path="$1"
  case "$path" in
    # These files can influence many modules, but local pre-push remains
    # targeted and defers full-suite coverage to CI.
    package.json|package-lock.json|pnpm-lock.yaml|yarn.lock|npm-shrinkwrap.json)
      return 0
      ;;
    vitest.config.*|tests/setup.mjs)
      return 0
      ;;
    .githooks/pre-push|.githooks/pre-commit)
      return 0
      ;;
    preflight.mjs|setup.mjs)
      return 0
      ;;
  esac
  return 1
}

merge_base_for_new_branch() {
  local local_sha="$1"
  git merge-base "$local_sha" origin/main 2>/dev/null \
    || git merge-base "$local_sha" origin/master 2>/dev/null \
    || true
}

while IFS= read -r line; do
  [ -z "$line" ] && continue
  LOCAL_SHA=$(printf '%s' "$line" | awk '{print $2}')
  REMOTE_SHA=$(printf '%s' "$line" | awk '{print $4}')

  # Branch deletion push: nothing local to validate.
  is_zero_sha "$LOCAL_SHA" && continue

  if is_zero_sha "$REMOTE_SHA"; then
    BASE="$(merge_base_for_new_branch "$LOCAL_SHA")"
    if [ -z "$BASE" ]; then
      while IFS= read -r path; do
        [ -z "$path" ] && continue
        CHANGED_MAP["$path"]=1
      done < <(git diff --name-only "$LOCAL_SHA" 2>/dev/null || true)
      continue
    fi
    RANGE="${BASE}..${LOCAL_SHA}"
  else
    RANGE="${REMOTE_SHA}..${LOCAL_SHA}"
  fi

  while IFS= read -r path; do
    [ -z "$path" ] && continue
    CHANGED_MAP["$path"]=1
    if is_broad_impact_file "$path"; then
      BROAD_IMPACT_MAP["$path"]=1
    fi
  done < <(git diff --name-only "$RANGE" 2>/dev/null || true)
done <<< "$PUSH_INPUT"

# ── Classify changed files ──────────────────────────────────────────────────
declare -a CHANGED_FILES=()
declare -a CHANGED_RUNTIME=()
declare -a CHANGED_TESTS=()

for file in "${!CHANGED_MAP[@]}"; do
  CHANGED_FILES+=("$file")
  case "$file" in
    *.mjs|*.js|*.cjs|*.ts|*.tsx)
      CHANGED_RUNTIME+=("$file")
      ;;
  esac
  case "$file" in
    tests/*.test.mjs|tests/*.node.test.mjs)
      CHANGED_TESTS+=("$file")
      ;;
  esac
done

if [ "${#CHANGED_RUNTIME[@]}" -eq 0 ] && [ "${#CHANGED_TESTS[@]}" -eq 0 ]; then
  echo "[hooks] no runtime/test files changed — pre-push passed ✓"
  exit 0
fi

if [ "${#BROAD_IMPACT_MAP[@]}" -gt 0 ]; then
  echo "[hooks] broad-impact files changed; running targeted local coverage only and deferring full-suite coverage to CI"
fi

# ── Collect all targeted test files into a single set ────────────────────────
declare -A TARGET_TESTS=()

# Source 1: import-graph grep — find test files that import changed modules.
# This replaces `vitest related` so we avoid a separate vitest startup.
# We search for both the full path and the basename (without extension) to
# catch aliased and re-exported imports.
collect_import_linked_tests() {
  local changed_path="$1"
  local normalized="${changed_path//\\//}"
  [ -z "$normalized" ] && return 0

  # Search for import/require of this file in test files.
  local test_file
  while IFS= read -r test_file; do
    [ -z "$test_file" ] && continue
    TARGET_TESTS["$test_file"]=1
  done < <(rg -l --glob "*.test.mjs" --glob "*.node.test.mjs" -e "from.*['\"].*${normalized}" -e "import.*['\"].*${normalized}" -e "require.*['\"].*${normalized}" tests 2>/dev/null || true)

  # Also search by basename without extension for relative imports.
  local base
  base="$(basename "$normalized" .mjs)"
  base="${base%.js}"
  base="${base%.cjs}"
  if [ -n "$base" ] && [ "$base" != "index" ]; then
    while IFS= read -r test_file; do
      [ -z "$test_file" ] && continue
      TARGET_TESTS["$test_file"]=1
    done < <(rg -l --glob "*.test.mjs" --glob "*.node.test.mjs" -e "from.*['\"].*/${base}(\\.m?js)?['\"]" tests 2>/dev/null || true)
  fi
}

# Source 2: directly changed test files.
for test_file in "${CHANGED_TESTS[@]}"; do
  TARGET_TESTS["$test_file"]=1
done

# Source 3: module adjacency map — for each changed runtime file, find which
# module it belongs to and add the adjacent test globs.
collect_adjacent_tests() {
  local changed_path="$1"
  local normalized="${changed_path//\\//}"
  [ -z "$normalized" ] && return 0

  local entry prefix globs
  for entry in "${ADJACENCY_MAP[@]}"; do
    prefix="${entry%%|*}"
    # Support both directory prefixes ("workflow/") and exact filenames ("cli.mjs").
    local match=false
    if [[ "$prefix" == */ ]]; then
      [[ "$normalized" == ${prefix}* ]] && match=true
    else
      [[ "$normalized" == "$prefix" ]] && match=true
    fi
    if $match; then
      globs="${entry#*|}"
      IFS='|' read -ra GLOB_ARRAY <<< "$globs"
      local glob
      for glob in "${GLOB_ARRAY[@]}"; do
        while IFS= read -r test_file; do
          [ -z "$test_file" ] && continue
          TARGET_TESTS["$test_file"]=1
        done < <(find tests -maxdepth 1 \( -name "${glob}.test.mjs" -o -name "${glob}.node.test.mjs" \) 2>/dev/null || true)
      done
    fi
  done
}

# Source 4: ripgrep string-match linking (catches non-import references like
# string literals, comments, path references in test assertions).
collect_linked_static_tests() {
  local changed_path="$1"
  local normalized="${changed_path//\\//}"
  [ -z "$normalized" ] && return 0

  local -a candidates=("$normalized")
  if [[ "$normalized" == site/* ]]; then
    candidates+=("${normalized#site/}")
  elif [[ "$normalized" == ui/* ]]; then
    candidates+=("site/$normalized")
  fi

  local candidate test_file
  for candidate in "${candidates[@]}"; do
    while IFS= read -r test_file; do
      [ -z "$test_file" ] && continue
      TARGET_TESTS["$test_file"]=1
    done < <(rg -l -F --glob "*.test.mjs" -- "$candidate" tests 2>/dev/null || true)
  done
}

for file in "${CHANGED_RUNTIME[@]}"; do
  collect_import_linked_tests "$file"
  collect_adjacent_tests "$file"
  collect_linked_static_tests "$file"
done

# ── Split targeted tests by runner and keep memory bounded ───────────────────
TOTAL_TESTS="$(find tests -maxdepth 1 \( -name '*.test.mjs' -o -name '*.node.test.mjs' \) 2>/dev/null | wc -l | tr -d ' ')"
[ "$TOTAL_TESTS" -eq 0 ] && TOTAL_TESTS=187  # fallback

declare -a SORTED_TARGET_TESTS=()
while IFS= read -r test_file; do
  [ -z "$test_file" ] && continue
  SORTED_TARGET_TESTS+=("$test_file")
done < <(printf '%s\n' "${!TARGET_TESTS[@]}" | sort)

if [ "${#SORTED_TARGET_TESTS[@]}" -eq 0 ]; then
  echo "[hooks] no related tests found — pre-push passed ✓"
  exit 0
fi

declare -a FINAL_VITEST_LIST=()
declare -a FINAL_NODE_TEST_LIST=()
for test_file in "${SORTED_TARGET_TESTS[@]}"; do
  case "$test_file" in
    *.node.test.mjs)
      FINAL_NODE_TEST_LIST+=("$test_file")
      ;;
    *)
      FINAL_VITEST_LIST+=("$test_file")
      ;;
  esac
done

echo "[hooks] running ${#SORTED_TARGET_TESTS[@]}/${TOTAL_TESTS} targeted tests…"

run_vitest_batches() {
  local -a tests=("$@")
  [ "${#tests[@]}" -eq 0 ] && return 0

  local -a runner_args=(run --config vitest.config.mjs)
  local -a bounded_runner_args=("${runner_args[@]}" --maxWorkers 1)
  local batch_size=18
  if [ "${#tests[@]}" -le "$batch_size" ]; then
    node tools/vitest-runner.mjs "${bounded_runner_args[@]}" "${tests[@]}"
    return $?
  fi

  echo "[hooks] splitting vitest target set into batches to keep local memory bounded"
  local total="${#tests[@]}"
  local offset=0
  local batch=1
  while [ "$offset" -lt "$total" ]; do
    local -a slice=("${tests[@]:offset:batch_size}")
    echo "[hooks] vitest batch ${batch}: ${#slice[@]} files"
    node tools/vitest-runner.mjs "${bounded_runner_args[@]}" "${slice[@]}" || return $?
    offset=$((offset + batch_size))
    batch=$((batch + 1))
  done
}

run_node_test_batches() {
  local -a tests=("$@")
  [ "${#tests[@]}" -eq 0 ] && return 0

  local batch_size=12
  local total="${#tests[@]}"
  local offset=0
  local batch=1
  while [ "$offset" -lt "$total" ]; do
    local -a slice=("${tests[@]:offset:batch_size}")
    echo "[hooks] node-test batch ${batch}: ${#slice[@]} files"
    node --import ./tests/node-test-bootstrap.mjs --test "${slice[@]}" || return $?
    offset=$((offset + batch_size))
    batch=$((batch + 1))
  done
}

run_vitest_batches "${FINAL_VITEST_LIST[@]}"
run_node_test_batches "${FINAL_NODE_TEST_LIST[@]}"

echo "[hooks] pre-push checks passed ✓"
